# Analyst Agent — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

PYTHONPATH=/path/to/analyst-agent

# LLM API key — at least one provider is required
# Google Gemini: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# LangSmith tracing (optional but recommended for dev)
# LangSmith tracing (optional but recommended for dev)
export LANGSMITH_TRACING=true
export LANGSMITH_ENDPOINT=https://api.smith.langchain.com
export LANGSMITH_API_KEY=
export LANGSMITH_PROJECT="Analyst Agent"


# SEC EDGAR requires identification — use your name and email
# e.g. "Jane Doe jane@example.com"
SEC_HEADER=Your Name your@email.com

# Tavily API key (optional — enables web research tools)
# Get one at: https://tavily.com
TAVILY_API_KEY=
