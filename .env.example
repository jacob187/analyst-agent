# Required: Google Gemini LLM
# Get from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Required: SEC EDGAR identification
# SEC requires a contact email in the User-Agent header
SEC_HEADER=your_email@example.com

# Optional: Tavily web research (enables news, competitor, and industry analysis tools)
# Get from https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
